[Script Info]
; Deterministic burn-in subtitles for the GPU stream benchmark.
; Events span 4 hours because -stream_loop keeps output timestamps rising
; past the 60 s clip — shorter coverage would silently drop the burn cost.
ScriptType: v4.00+
PlayResX: 1920
PlayResY: 1080

[V4+ Styles]
Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding
Style: Default,sans-serif,52,&H00FFFFFF,&H00FFFFFF,&H00101010,&H64000000,0,0,1,2,1,2,60,60,60,1

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text
